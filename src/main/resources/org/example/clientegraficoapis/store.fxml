            </VBox>
            <VBox alignment="TOP_CENTER" spacing="5.0">
               <children>
                  <Label style="-fx-font-size: 16;" styleClass="label-subtitle" text="precioMax" />
                  <Spinner fx:id="spinnerMaxPrice" />
               </children>
            </VBox>
            <Button fx:id="filterButton" mnemonicParsing="false" onAction="#filter" prefHeight="48.0" prefWidth="97.0" style="-fx-font-size: 16px;" styleClass="button-amazon" text="Filtrar">
               <font>
                  <Font size="20.0" />
               </font>
            </Button>
         </children>
      </HBox>
    </children>
</AnchorPane>
