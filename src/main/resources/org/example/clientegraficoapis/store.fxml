<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1024.0"
            prefWidth="1280.0" style="-fx-background-color: #E5E7E8;" stylesheets="@../../../css/amazon.css"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.clientegraficoapis.controller.storeController">
    <children>
        <HBox alignment="TOP_CENTER" layoutX="-9.0" prefHeight="56.0" prefWidth="1290.0" styleClass="nav-bar">
            <children>
                <VBox alignment="TOP_CENTER" prefHeight="1.0" prefWidth="68.0">
                    <children>
                        <Label prefWidth="82.0" text="Amazon't">
                            <font>
                                <Font name="Arial Bold" size="96.0"/>
                            </font>
                        </Label>
                        <ImageView fitHeight="102.0" fitWidth="68.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../../../images/logo.png"/>
                            </image>
                        </ImageView>
                    </children>
                </VBox>
            </children>
        </HBox>
        <TableView fx:id="tvProductos" layoutY="307.0" prefHeight="718.0" prefWidth="1280.0">
            <columns>
                <TableColumn fx:id="idProducto" prefWidth="105.0" text="Id"/>
                <TableColumn fx:id="nombreProducto" prefWidth="276.0" text="Nombre"/>
                <TableColumn fx:id="descProducto" prefWidth="592.0" text="Descripcion"/>
                <TableColumn fx:id="precioProducto" prefWidth="306.0" text="Precio"/>
            </columns>
        </TableView>
        <Label layoutX="488.0" layoutY="89.0" style="-fx-font-size: 60;" styleClass="label-title" text="Productos"/>
        <Button fx:id="botonComprar" layoutX="546.0" layoutY="215.0" mnemonicParsing="false" prefHeight="43.0"
                prefWidth="182.0" style="-fx-font-size: 20px;" styleClass="button-buy" text="Comprar">
            <font>
                <Font size="20.0"/>
            </font>
        </Button>
        <VBox layoutX="1049.0" layoutY="89.0" spacing="20.0">
            <children>
                <Button fx:id="botonCrear" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
                        minWidth="-Infinity" mnemonicParsing="false" prefHeight="43.0" prefWidth="182.0"
                        styleClass="button-create" text="Crear Producto">
                    <font>
                        <Font size="20.0"/>
                    </font>
                </Button>
                <Button fx:id="botonMod" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
                        minWidth="-Infinity" mnemonicParsing="false" prefHeight="43.0" prefWidth="182.0"
                        styleClass="button-modify" text="Modificar Producto">
                    <font>
                        <Font size="20.0"/>
                    </font>
                </Button>
                <Button fx:id="botonBorrar" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
                        minWidth="-Infinity" mnemonicParsing="false" prefHeight="43.0" prefWidth="182.0"
                        styleClass="button-delete" text="Borrar Producto">
                    <font>
                        <Font size="20.0"/>
                    </font>
                </Button>
            </children>
        </VBox>
        <Label layoutX="430.0" layoutY="186.0" style="-fx-font-size: 16;" styleClass="label-subtitle"
               text="Seleccione el producto que desea comprar y pulse el boton"/>
    </children>
</AnchorPane>
